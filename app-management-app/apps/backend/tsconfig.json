{
    // Use the root directory for configuration
    // any overriding configs defined here
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
      "target": "ES6",
      "module": "commonjs",
      "rootDir": "../../",
      "outDir": "./dist",

      "sourceMap": true,
      "lib": ["ESNext"],
      "baseUrl": "./",
      "paths": {
        "@shared/*": ["../../shared/*"]
      }
    },
    "include": ["src/**/*", "tests/**/*","global.d.ts", "../../shared/**/*"],
    "exclude": ["node_modules", "dist"]
}
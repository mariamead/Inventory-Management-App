{
  "name": "app-management-app",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "start:frontend": "npm run dev --workspace=@app-management-app/frontend",
    "start:backend": "npm start --workspace=@app-management-app/backend",
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\""
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "typescript": "^5.0.0"
  }
}